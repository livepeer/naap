DATABASE_URL="postgresql://postgres:postgres@localhost:5432/naap"

# The Graph API key (required for delegator counts, fee volumes, and charts)
# Get a free key at https://thegraph.com/studio/apikeys/
SUBGRAPH_API_KEY=

# CoinGecko API key (optional, for higher rate limits)
COINGECKO_API_KEY=

# Vercel Cron secret (auto-set by Vercel, used to protect cron endpoints)
CRON_SECRET=

# Set to "true" to disable cron jobs in Express mode
DISABLE_CRON=
