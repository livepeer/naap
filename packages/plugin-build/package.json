{
  "name": "@naap/plugin-build",
  "version": "0.1.0",
  "description": "Shared build configuration for NAAP plugins",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.js"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./dist/vite.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "8.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "typescript": "~5.9.3"
  },
  "keywords": [
    "naap",
    "plugin",
    "build",
    "vite",
    "umd"
  ],
  "author": "NAAP Team",
  "license": "MIT"
}
