{
  "$schema": "./connector-template.schema.json",
  "id": "clickhouse",
  "name": "ClickHouse",
  "description": "ClickHouse HTTP query interface with Basic auth — run SQL queries against a ClickHouse instance via its native HTTP API",
  "icon": "📊",
  "category": "database",
  "connector": {
    "slug": "clickhouse",
    "displayName": "ClickHouse",
    "description": "ClickHouse HTTP query interface with Basic auth and SELECT-only enforcement",
    "category": "database",
    "upstreamBaseUrl": "https://s7kh1yt2go.us-east-2.aws.clickhouse.cloud:8443",
    "defaultTimeout": 30000,
    "healthCheckPath": "/ping",
    "authType": "basic",
    "authConfig": { "usernameRef": "username", "passwordRef": "password" },
    "secretRefs": ["username", "password"],
    "streamingEnabled": false,
    "tags": ["clickhouse", "analytics", "database", "sql", "olap"]
  },
  "endpoints": [
    {
      "name": "query",
      "description": "Execute a SELECT or WITH...SELECT query — consumer sends raw SQL as the request body",
      "method": "POST",
      "path": "/query",
      "upstreamPath": "/",
      "upstreamContentType": "text/plain",
      "bodyTransform": "passthrough",
      "bodyBlacklist": ["DROP", "DELETE", "INSERT", "UPDATE", "ALTER", "CREATE", "TRUNCATE"],
      "bodyPattern": "^\\s*(?:[Ss][Ee][Ll][Ee][Cc][Tt]|[Ww][Ii][Tt][Hh])\\b",
      "timeout": 30000
    },
    {
      "name": "ping",
      "description": "ClickHouse health check",
      "method": "GET",
      "path": "/ping",
      "upstreamPath": "/ping",
      "cacheTtl": 5
    }
  ]
}
