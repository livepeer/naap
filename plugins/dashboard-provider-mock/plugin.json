{
  "$schema": "https://plugins.naap.io/schema/plugin.json",
  "name": "dashboard-provider-mock",
  "displayName": "Dashboard Provider",
  "version": "1.0.0",
  "description": "Dashboard data provider backed by the Livepeer Leaderboard API, subgraph, and L1 RPC. Serves live KPI, pipelines, GPU capacity, orchestrators, protocol, and fees via the GraphQL-over-event-bus contract.",
  "author": {
    "name": "NAAP Team",
    "email": "team@naap.io"
  },
  "license": "MIT",
  "keywords": ["dashboard", "provider", "leaderboard", "reference"],
  "category": "analytics",

  "shell": {
    "minVersion": "0.1.0",
    "maxVersion": "2.x"
  },

  "frontend": {
    "entry": "./frontend/dist/production/dashboard-provider-mock.js",
    "devPort": 3020,
    "routes": []
  },

  "permissions": {
    "shell": ["notifications"]
  }
}
