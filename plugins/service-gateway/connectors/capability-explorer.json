{
  "$schema": "./connector-template.schema.json",
  "id": "capability-explorer",
  "name": "Capability Explorer",
  "description": "Query Livepeer network AI capabilities — enriched with HuggingFace metadata, performance metrics, and pricing",
  "icon": "🔍",
  "category": "ai",
  "connector": {
    "slug": "capability-explorer",
    "displayName": "Capability Explorer",
    "description": "Livepeer AI capability discovery and exploration API",
    "category": "ai",
    "upstreamBaseUrl": "${NEXT_PUBLIC_APP_URL}",
    "defaultTimeout": 10000,
    "healthCheckPath": "/api/v1/capability-explorer/stats",
    "authType": "bearer",
    "authConfig": { "tokenRef": "token" },
    "secretRefs": ["token"],
    "streamingEnabled": false,
    "tags": ["capability", "explorer", "ai", "livepeer", "discovery"]
  },
  "endpoints": [
    {
      "name": "capabilities",
      "description": "List and filter all network capabilities with enriched metadata",
      "method": "GET",
      "path": "/capabilities",
      "upstreamPath": "/api/v1/capability-explorer/capabilities",
      "timeout": 5000,
      "cacheTtl": 60
    },
    {
      "name": "capability",
      "description": "Get a single capability by ID with full detail",
      "method": "GET",
      "path": "/capabilities/:id",
      "upstreamPath": "/api/v1/capability-explorer/capabilities/${id}",
      "timeout": 5000,
      "cacheTtl": 60
    },
    {
      "name": "categories",
      "description": "List capability categories with counts",
      "method": "GET",
      "path": "/categories",
      "upstreamPath": "/api/v1/capability-explorer/categories",
      "timeout": 5000,
      "cacheTtl": 120
    },
    {
      "name": "stats",
      "description": "Get aggregated network capability statistics",
      "method": "GET",
      "path": "/stats",
      "upstreamPath": "/api/v1/capability-explorer/stats",
      "timeout": 5000,
      "cacheTtl": 120
    },
    {
      "name": "graphql",
      "description": "GraphQL endpoint for flexible capability queries",
      "method": "POST",
      "path": "/graphql",
      "upstreamPath": "/api/v1/capability-explorer/graphql",
      "timeout": 10000,
      "cacheTtl": 30
    },
    {
      "name": "query-results",
      "description": "Evaluate a saved capability query and return filtered results",
      "method": "GET",
      "path": "/queries/:id/results",
      "upstreamPath": "/api/v1/capability-explorer/queries/${id}/results",
      "timeout": 5000,
      "cacheTtl": 60
    }
  ]
}
